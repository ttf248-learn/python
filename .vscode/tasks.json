{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "安装network_topology依赖",
            "type": "shell",
            "command": "pip3",
            "args": [
                "install",
                "-r",
                "${workspaceFolder}/scripts/network_topology/requirements.txt"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": []
        },
        {
            "label": "运行network_topology脚本",
            "type": "shell",
            "command": "python3",
            "args": [
                "${workspaceFolder}/scripts/network_topology/process_network_topology.py"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": []
        },
        {
            "label": "查看帮助",
            "type": "shell",
            "command": "python3",
            "args": [
                "${workspaceFolder}/scripts/network_topology/process_network_topology.py",
                "--help"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": []
        },
        {
            "label": "检查网络拓扑目录",
            "type": "shell",
            "command": "ls",
            "args": [
                "-la",
                "${workspaceFolder}/scripts/network_topology"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": []
        },
        {
            "label": "清理输出文件",
            "type": "shell",
            "command": "rm",
            "args": [
                "-rf",
                "${workspaceFolder}/scripts/network_topology/output/*"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": []
        }
    ]
}
